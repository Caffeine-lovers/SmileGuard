{
  "name": "smileguard",
  "version": "1.0.0",
  "description": "SmileGuard - AI-powered dental management system",
  "scripts": {
    "doctor:android": "pnpm --filter doctor-mobile android",
    "doctor:ios": "pnpm --filter doctor-mobile ios",
    "patient:dev": "pnpm --filter patient-web dev",
    "patient:build": "pnpm --filter patient-web build",
    "lint": "pnpm --filter doctor-mobile lint",
    "test": "pnpm --filter @smileguard/tests test",
    "test:watch": "pnpm --filter @smileguard/tests test:watch",
    "test:coverage": "pnpm --filter @smileguard/tests test:coverage",
    "type-check": "pnpm --filter patient-web type-check && pnpm --filter doctor-mobile tsc --noEmit",
    "eas-build-pre-install": "corepack enable && corepack prepare pnpm@9.0.0 --activate",
    "doctor:start": "pnpm --filter doctor-mobile start"
  },
  "dependencies": {
    "expo": "53.0.0",
    "expo-constants": "~17.1.8",
    "expo-device": "~7.1.4",
    "expo-notifications": "~0.31.5",
    "react": "^19.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  },
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-screens": "4.16.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "19.1.0",
    "@babel/core": "^7.26.0"
    }
  }
}



