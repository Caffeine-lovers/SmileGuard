{
  "expo": {
    "name": "smileguard",
    "slug": "smileguard-doctor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "smileguard",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.TurtleStudios.smileguard",
      "edgeToEdgeEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "smileguard",
              "pathPrefix": "/auth/callback"
            },
            {
              "scheme": "smileguard",
              "pathPrefix": "/oauth-redirect"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],

      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "supabaseUrl": "https://yffvnvusiazjnwmdylji.supabase.co",
